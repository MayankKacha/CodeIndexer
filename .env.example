# ===== OpenAI =====
OPENAI_API_KEY=sk-
OPENAI_MODEL=gpt-4o-mini
GRAPH_BACKEND=networkx

# ===== Neo4j =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ===== Milvus =====
# For Milvus Lite (local, zero setup): use a file path
MILVUS_URI=./milvus_code.db
# For Zilliz Cloud: use the cloud URI
# MILVUS_URI=https://your-instance.zillizcloud.com
# MILVUS_TOKEN=your-token

MILVUS_COLLECTION=code_elements

# ===== Encoder =====
ENCODER_MODEL=microsoft/codebert-base
# Options: cpu, cuda, mps (Apple Silicon)
ENCODER_DEVICE=cpu

# ===== Search =====
BM25_WEIGHT=0.5
VECTOR_WEIGHT=0.5
RERANK_TOP_K=50
FINAL_TOP_K=10

# ===== Compression =====
# Options: extractive, summary, hybrid
COMPRESSION_STRATEGY=hybrid
MAX_COMPRESSED_TOKENS=2000

# ===== Cache =====
CACHE_DIR=./.codeindexer_cache
CACHE_TTL=3600

# ===== API Server =====
API_HOST=0.0.0.0
API_PORT=8000
